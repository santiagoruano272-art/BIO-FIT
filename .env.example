# ============================================================
#  BIO-FIT — .env.example
#  Copia este archivo como .env y llena los valores reales.
#  NUNCA subas el .env real a git.
# ============================================================

# ── Django ──────────────────────────────────────────────────
SECRET_KEY=django-insecure-cambia-esto-en-produccion-usa-una-clave-larga
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Firebase ─────────────────────────────────────────────────
# Ruta al archivo JSON descargado desde Firebase Console
# Firebase Console → Configuración del proyecto → Cuentas de servicio
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Anthropic (Claude API) ───────────────────────────────────
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenAI (opcional, para fallback) ────────────────────────
# OPENAI_API_KEY=sk-...

# ── Base de datos (producción — PostgreSQL) ──────────────────
# En desarrollo usa SQLite (no necesitas esta variable)
# DATABASE_URL=postgresql://user:password@localhost:5432/biofit

# ── Email (para notificaciones) ──────────────────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=tu-email@gmail.com
# EMAIL_HOST_PASSWORD=app-password-de-gmail
